#compdef clawsec

_clawsec() {
    _arguments \
        '-l[Listen mode for inbound connections]' \
        '-p[Local port number]:port:' \
        '-k[Encryption password (required)]:password:' \
        '-u[UDP mode (default: TCP)]' \
        '-4[Force IPv4 only]' \
        '-6[Force IPv6 only]' \
        '-c[Chat mode with timestamps and colors]' \
        '-v[Verbose output]' \
        '-w[Connection timeout in seconds]:seconds:' \
        '-K[Keep-open: accept multiple clients (fork per client)]' \
        '-L[Port forwarding target]:host\:port:' \
        '--obfs[Traffic obfuscation mode]:mode:(http)' \
        '-z[Compress data with zlib before encryption]' \
        '-P[Show transfer progress bar]' \
        '-V[SHA-256 end-to-end file verification]' \
        '-e[Execute program after connect]:program:_command_names' \
        '-h[Display usage information]' \
        '*:host:_hosts'
}

_clawsec "$@"
